{
  "name": "@lastest/runner",
  "version": "0.5.1",
  "description": "Remote test execution runner for Lastest visual regression testing platform",
  "type": "module",
  "bin": {
    "lastest-runner": "./bin/lastest-runner.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
