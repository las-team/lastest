{
  "name": "@lastest/runner",
  "version": "0.1.1",
  "description": "Remote test execution runner for Lastest2 visual regression testing platform",
  "type": "module",
  "bin": {
    "lastest2-runner": "./bin/lastest2-runner.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "playwright": "^1.48.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "visual-regression",
    "playwright",
    "testing",
    "runner",
    "lastest2",
    "screenshot",
    "ci-cd"
  ],
  "author": "Dexilion Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dexilion-team/lastest2.git",
    "directory": "packages/runner"
  },
  "homepage": "https://github.com/dexilion-team/lastest2#readme",
  "bugs": {
    "url": "https://github.com/dexilion-team/lastest2/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
