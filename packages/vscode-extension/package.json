{
  "name": "lastest-vscode",
  "displayName": "Lastest Visual Testing",
  "description": "Visual regression testing integration for Lastest — record, run, and review screenshot diffs without leaving VS Code.",
  "version": "0.1.0",
  "publisher": "lastest",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://lastest.cloud",
  "repository": {
    "type": "git",
    "url": "https://github.com/las-team/lastest.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/las-team/lastest/issues"
  },
  "keywords": [
    "visual regression",
    "testing",
    "playwright",
    "screenshot diff",
    "baseline",
    "qa",
    "ai testing",
    "lastest"
  ],
  "galleryBanner": {
    "color": "#0a0a0a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing",
    "Visualization",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lastest",
          "title": "Lastest",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "lastest": [
        {
          "id": "lastest.testExplorer",
          "name": "Test Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "lastest.runTest",
        "title": "Run Test",
        "icon": "$(play)"
      },
      {
        "command": "lastest.runAllTests",
        "title": "Run All Tests",
        "icon": "$(run-all)"
      },
      {
        "command": "lastest.refreshTests",
        "title": "Refresh Tests",
        "icon": "$(refresh)"
      },
      {
        "command": "lastest.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "lastest.runAllTests",
          "when": "view == lastest.testExplorer",
          "group": "navigation"
        },
        {
          "command": "lastest.refreshTests",
          "when": "view == lastest.testExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "lastest.runTest",
          "when": "view == lastest.testExplorer && viewItem == test",
          "group": "inline"
        },
        {
          "command": "lastest.runTest",
          "when": "view == lastest.testExplorer && viewItem == functionalArea",
          "group": "inline"
        },
        {
          "command": "lastest.openInBrowser",
          "when": "view == lastest.testExplorer && viewItem == test",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Lastest",
      "properties": {
        "lastest.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "URL of the Lastest server"
        },
        "lastest.apiToken": {
          "type": "string",
          "default": "",
          "description": "API token for authentication"
        },
        "lastest.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh test list after runs"
        },
        "lastest.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show test status in status bar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build": "npm run compile",
    "watch": "npm run compile -- --watch",
    "package": "vsce package",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5"
  }
}
