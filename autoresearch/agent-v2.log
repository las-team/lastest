{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BWmbRvX9r5WHQFur8DPbwM","type":"tool_result","content":"   818→export function extractCodeFromResponse(response: string): string {\n   819→  // Try to extract code from markdown code blocks (any language tag or none)\n   820→  const codeBlockMatch = response.match(/```(?:\\w*)?\\n([\\s\\S]*?)```/);\n   821→  if (codeBlockMatch) {\n   822→    return codeBlockMatch[1].trim();\n   823→  }\n   824→\n   825→  // If no code block, check if response starts with import or export\n   826→  if (response.trim().startsWith('import') || response.trim().startsWith('export')) {\n   827→    return response.trim();\n   828→  }\n   829→\n   830→  // Look for export async function anywhere in the response (AI may have added explanation before code)\n   831→  const funcMatch = response.match(/(export\\s+async\\s+function\\s+test\\s*\\([\\s\\S]*)/);\n   832→  if (funcMatch) {\n   833→    return funcMatch[1].trim();\n   834→  }\n   835→\n   836→  // Look for import statement followed by code anywhere in the response\n   837→  const importMatch = response.match(/(import\\s+[\\s\\S]*export\\s+async\\s+function[\\s\\S]*)/);\n   838→  if (importMatch) {\n   839→    return importMatch[1].trim();\n   840→  }\n   841→\n   842→  // If no code patterns found, the response is likely explanatory text, not code.\n   843→  // Check for actual code patterns (not just mentions of words in prose)\n   844→  const trimmed = response.trim();\n   845→  const hasCodePattern = /(?:^|\\n)\\s*(?:export\\s+|async\\s+function|const\\s+\\w+\\s*=|let\\s+\\w+\\s*=|await\\s+page\\.|page\\.goto|page\\.locator|stepLogger\\.log)/.test(trimmed);\n   846→  if (!hasCodePattern) {\n   847→    return '';\n   848→  }\n   849→\n   850→  // Return as-is if we can't extract but it looks code-like\n   851→  return trimmed;\n   852→}"}]},"parent_tool_use_id":null,"session_id":"ec911d5a-d516-40b8-8771-7468f6b1ba97","uuid":"eaf6471a-8f1b-43bd-867b-f7ebf7d2527e","tool_use_result":{"type":"text","file":{"filePath":"/home/ewyct/dev/lastest2/src/lib/ai/prompts.ts","content":"export function extractCodeFromResponse(response: string): string {\n  // Try to extract code from markdown code blocks (any language tag or none)\n  const codeBlockMatch = response.match(/```(?:\\w*)?\\n([\\s\\S]*?)```/);\n  if (codeBlockMatch) {\n    return codeBlockMatch[1].trim();\n  }\n\n  // If no code block, check if response starts with import or export\n  if (response.trim().startsWith('import') || response.trim().startsWith('export')) {\n    return response.trim();\n  }\n\n  // Look for export async function anywhere in the response (AI may have added explanation before code)\n  const funcMatch = response.match(/(export\\s+async\\s+function\\s+test\\s*\\([\\s\\S]*)/);\n  if (funcMatch) {\n    return funcMatch[1].trim();\n  }\n\n  // Look for import statement followed by code anywhere in the response\n  const importMatch = response.match(/(import\\s+[\\s\\S]*export\\s+async\\s+function[\\s\\S]*)/);\n  if (importMatch) {\n    return importMatch[1].trim();\n  }\n\n  // If no code patterns found, the response is likely explanatory text, not code.\n  // Check for actual code patterns (not just mentions of words in prose)\n  const trimmed = response.trim();\n  const hasCodePattern = /(?:^|\\n)\\s*(?:export\\s+|async\\s+function|const\\s+\\w+\\s*=|let\\s+\\w+\\s*=|await\\s+page\\.|page\\.goto|page\\.locator|stepLogger\\.log)/.test(trimmed);\n  if (!hasCodePattern) {\n    return '';\n  }\n\n  // Return as-is if we can't extract but it looks code-like\n  return trimmed;\n}","numLines":35,"startLine":818,"totalLines":853}}}
