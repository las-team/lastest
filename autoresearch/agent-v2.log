{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RYFcwd1PSiDMXXewvWczXw","type":"tool_result","content":"   890→function groupAcceptanceCriteria(\n   891→  criteria: ExtractedAcceptanceCriterion[]\n   892→): ExtractedAcceptanceCriterion[][] {\n   893→  const groups: Map<string, ExtractedAcceptanceCriterion[]> = new Map();\n   894→\n   895→  for (const ac of criteria) {\n   896→    const groupKey = ac.groupedWith || ac.id;\n   897→    const existing = groups.get(groupKey) || [];\n   898→    existing.push(ac);\n   899→    groups.set(groupKey, existing);\n   900→  }\n   901→\n   902→  return Array.from(groups.values());\n   903→}\n   904→\n   905→// ============================================\n   906→// Step 4: Optional MCP validation\n   907→// ============================================\n   908→\n   909→export async function validateTestWithMCP(\n   910→  repositoryId: string,\n   911→  testId: string,\n   912→  baseUrl: string\n   913→): Promise<ValidateTestResponse> {\n   914→  await requireRepoAccess(repositoryId);\n   915→  try {\n   916→    // Check if baseUrl is localhost\n   917→    const url = new URL(baseUrl);\n   918→    if (url.hostname !== 'localhost' && url.hostname !== '127.0.0.1') {\n   919→      return { success: false, passed: false, error: 'MCP validation is only available for localhost targets' };\n   920→    }\n   921→\n   922→    const test = await queries.getTest(testId);\n   923→    if (!test) {\n   924→      return { success: false, passed: false, error: 'Test not found' };\n   925→    }\n   926→\n   927→    const config = await getAIConfig(repositoryId);\n   928→\n   929→    // Use MCP to validate and fix the test\n   930→    const prompt = `Validate and fix this Playwright test by running it against the live application.\n   931→\n   932→Test code:\n   933→\\`\\`\\`typescript\n   934→${test.code}\n   935→\\`\\`\\`\n   936→\n   937→Base URL: ${baseUrl}\n   938→\n   939→Steps:\n   940→1. Use browser_navigate to go to the target URL\n   941→2. Use browser_snapshot to verify the page structure\n   942→3. Check if the selectors in the test code would work on this page\n   943→4. If selectors are wrong or the page structure differs, provide FIXED test code\n   944→5. Verify assertions would pass against the current page state\n   945→\n   946→If the test looks correct, return the original code unchanged.\n   947→If fixes are needed, return the FIXED code.\n   948→\n   949→Return ONLY the code (fixed or original), no explanations.`;"}]},"parent_tool_use_id":null,"session_id":"ec911d5a-d516-40b8-8771-7468f6b1ba97","uuid":"1ebb3596-d92b-4638-9348-687696f5daff","tool_use_result":{"type":"text","file":{"filePath":"/home/ewyct/dev/lastest2/src/server/actions/spec-import.ts","content":"function groupAcceptanceCriteria(\n  criteria: ExtractedAcceptanceCriterion[]\n): ExtractedAcceptanceCriterion[][] {\n  const groups: Map<string, ExtractedAcceptanceCriterion[]> = new Map();\n\n  for (const ac of criteria) {\n    const groupKey = ac.groupedWith || ac.id;\n    const existing = groups.get(groupKey) || [];\n    existing.push(ac);\n    groups.set(groupKey, existing);\n  }\n\n  return Array.from(groups.values());\n}\n\n// ============================================\n// Step 4: Optional MCP validation\n// ============================================\n\nexport async function validateTestWithMCP(\n  repositoryId: string,\n  testId: string,\n  baseUrl: string\n): Promise<ValidateTestResponse> {\n  await requireRepoAccess(repositoryId);\n  try {\n    // Check if baseUrl is localhost\n    const url = new URL(baseUrl);\n    if (url.hostname !== 'localhost' && url.hostname !== '127.0.0.1') {\n      return { success: false, passed: false, error: 'MCP validation is only available for localhost targets' };\n    }\n\n    const test = await queries.getTest(testId);\n    if (!test) {\n      return { success: false, passed: false, error: 'Test not found' };\n    }\n\n    const config = await getAIConfig(repositoryId);\n\n    // Use MCP to validate and fix the test\n    const prompt = `Validate and fix this Playwright test by running it against the live application.\n\nTest code:\n\\`\\`\\`typescript\n${test.code}\n\\`\\`\\`\n\nBase URL: ${baseUrl}\n\nSteps:\n1. Use browser_navigate to go to the target URL\n2. Use browser_snapshot to verify the page structure\n3. Check if the selectors in the test code would work on this page\n4. If selectors are wrong or the page structure differs, provide FIXED test code\n5. Verify assertions would pass against the current page state\n\nIf the test looks correct, return the original code unchanged.\nIf fixes are needed, return the FIXED code.\n\nReturn ONLY the code (fixed or original), no explanations.`;","numLines":60,"startLine":890,"totalLines":997}}}
