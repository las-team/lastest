70→- Verify all brackets/parens are balanced before outputting\n    71→\n    72→SELECTORS — this app uses shadcn/ui + Tailwind CSS:\n    73→- Buttons: page.getByRole('button', { name: '...' })\n    74→- Links: page.getByRole('link', { name: '...' })\n    75→- Inputs: page.getByRole('textbox') or page.getByLabel('...')\n    76→- Tabs: page.getByRole('tab', { name: '...' })\n    77→- Dialogs: page.getByRole('dialog')\n    78→- Tables: page.getByRole('table'), page.getByRole('row')\n    79→- Headings: page.getByRole('heading', { name: '...' })\n    80→- Prefer getByRole() > getByText() > page.locator('[data-testid]') > CSS selectors\n    81→\n    82→ASSERTIONS — prefer resilient checks:\n    83→- Use toContainText() over exact toHaveText() when possible\n    84→- NEVER use toBeTruthy() on textContent() or getAttribute() results — they return null when missing\n    85→- WRONG: const t = await el.textContent(); expect(t).toBeTruthy()\n    86→- RIGHT: await expect(el).toBeVisible() or await expect(el).toContainText(/expected/)\n    87→- Prefer toBeVisible() for element presence checks\n    88→- If checking a count, use toHaveCount() with the expected number\n    89→\n    90→EXAMPLE (static route):\n    91→\\`\\`\\`javascript\n    92→export async function test(page, baseUrl, screenshotPath, stepLogger) {\n    93→  stepLogger.log('Navigate');\n    94→  await page.goto(\\`\\${baseUrl}/settings\\`, { waitUntil: 'domcontentloaded' });\n    95→  await page.waitForLoadState('domcontentloaded');\n    96→  await expect(page).toHaveURL(/\\\\/settings/);\n    97→  await expect(page.locator('body')).toBeVisible();\n    98→  stepLogger.log('Screenshot');\n    99→  await page.screenshot({ path: screenshotPath, fullPage: true });\n   100→}\n   101→\\`\\`\\`\n   102→\n   103→EXAMPLE (dynamic route — discover real ID from list page):\n   104→\\`\\`\\`javascript\n   105→export async function test(page, baseUrl, screenshotPath, stepLogger) {"}]},"parent_tool_use_id":null,"session_id":"ec911