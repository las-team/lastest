{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JkNV2EvsejMyE8CUKj4Lo9","type":"tool_result","content":"   890→function groupAcceptanceCriteria(\n   891→  criteria: ExtractedAcceptanceCriterion[]\n   892→): ExtractedAcceptanceCriterion[][] {\n   893→  const groups: Map<string, ExtractedAcceptanceCriterion[]> = new Map();\n   894→\n   895→  for (const ac of criteria) {\n   896→    // Use explicit grouping if set\n   897→    if (ac.groupedWith) {\n   898→      const existing = groups.get(ac.groupedWith) || [];\n   899→      existing.push(ac);\n   900→      groups.set(ac.groupedWith, existing);\n   901→      continue;\n   902→    }\n   903→\n   904→    // Auto-detect route mentions in AC description to group by route\n   905→    const routeMatch = ac.description.match(/\\/[\\w-]+(?:\\/[\\w-[\\]]+)*/);\n   906→    const routeKey = routeMatch ? routeMatch[0] : ac.id;\n   907→\n   908→    const existing = groups.get(routeKey) || [];\n   909→    existing.push(ac);\n   910→    groups.set(routeKey, existing);\n   911→  }\n   912→\n   913→  // Cap groups at 3 ACs to keep tests focused\n   914→  const result: ExtractedAcceptanceCriterion[][] = [];\n   915→  for (const group of groups.values()) {\n   916→    if (group.length <= 3) {\n   917→      result.push(group);\n   918→    } else {\n   919→      // Split large groups into chunks of 3\n   920→      for (let i = 0; i < group.length; i += 3) {\n   921→        result.push(group.slice(i, i + 3));\n   922→      }\n   923→    }\n   924→  }\n   925→\n   926→  return result;\n   927→}\n   928→\n   929→// ============================================"}]},"parent_tool_use_id":null,"session_id":"ec911d5a-d516-40b8-8771-7468f6b1ba97","uuid":"ed370243-9200-453c-9ee9-bec6ab5c1ce0","tool_use_result":{"type":"text","file":{"filePath":"/home/ewyct/dev/lastest2/src/server/actions/spec-import.ts","content":"function groupAcceptanceCriteria(\n  criteria: ExtractedAcceptanceCriterion[]\n): ExtractedAcceptanceCriterion[][] {\n  const groups: Map<string, ExtractedAcceptanceCriterion[]> = new Map();\n\n  for (const ac of criteria) {\n    // Use explicit grouping if set\n    if (ac.groupedWith) {\n      const existing = groups.get(ac.groupedWith) || [];\n      existing.push(ac);\n      groups.set(ac.groupedWith, existing);\n      continue;\n    }\n\n    // Auto-detect route mentions in AC description to group by route\n    const routeMatch = ac.description.match(/\\/[\\w-]+(?:\\/[\\w-[\\]]+)*/);\n    const routeKey = routeMatch ? routeMatch[0] : ac.id;\n\n    const existing = groups.get(routeKey) || [];\n    existing.push(ac);\n    groups.set(routeKey, existing);\n  }\n\n  // Cap groups at 3 ACs to keep tests focused\n  const result: ExtractedAcceptanceCriterion[][] = [];\n  for (const group of groups.values()) {\n    if (group.length <= 3) {\n      result.push(group);\n    } else {\n      // Split large groups into chunks of 3\n      for (let i = 0; i < group.length; i += 3) {\n        result.push(group.slice(i, i + 3));\n      }\n    }\n  }\n\n  return result;\n}\n\n// ============================================","numLines":40,"startLine":890,"totalLines":1021}}}
