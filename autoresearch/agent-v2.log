{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D4e298PW95ktBEvVZCcuY7","type":"tool_result","content":"     1→/**\n     2→ * autoresearch/harness/full-eval.ts — Full Pipeline Eval (IMMUTABLE)\n     3→ *\n     4→ * Triggers an actual Play Agent run and polls until completion.\n     5→ * Outputs metrics in the same parseable format.\n     6→ *\n     7→ * Usage:\n     8→ *   pnpm tsx autoresearch/harness/full-eval.ts --repo-id=<id>\n     9→ */\n    10→\n    11→// Allow nested Claude CLI sessions\n    12→delete process.env.CLAUDECODE;\n    13→\n    14→import { db } from '@/lib/db';\n    15→import { agentSessions, builds, testRuns } from '@/lib/db/schema';\n    16→import { eq, desc, and } from 'drizzle-orm';\n    17→import { getLatestBuildMetrics } from './metrics';\n    18→\n    19→// ─── Types ──────────────────────────────────────────────────────\n    20→\n    21→type AgentSessionStatus = 'active' | 'paused' | 'completed' | 'failed' | 'cancelled';\n    22→\n    23→// ─── Config ─────────────────────────────────────────────────────\n    24→\n    25→const POLL_INTERVAL_MS = 15_000; // 15 seconds\n    26→const MAX_WAIT_MS = 20 * 60 * 1000; // 20 minutes\n    27→\n    28→// ─── Play Agent Trigger ─────────────────────────────────────────\n    29→\n    30→async function triggerPlayAgent(repositoryId: string): Promise<string> {\n    31→  // Import startPlayAgent dynamically to avoid server action context issues\n    32→  // Instead, we directly create the agent session and kick off execution\n    33→  // by calling the HTTP endpoint or the function directly\n    34→\n    35→  // Use the server action via dynamic import\n    36→  const { startPlayAgent } = await import('@/server/actions/play-agent');\n    37→  const result = await startPlayAgent(repositoryId);\n    38→  return result.sessionId;\n    39→}\n    40→\n    41→// ─── Polling ────────────────────────────────────────────────────\n    42→\n    43→async function waitForCompletion(sessionId: string): Promise<{\n    44→  status: AgentSessionStatus;\n    45→  durationMs: number;\n    46→}> {\n    47→  const startTime = Date.now();\n    48→\n    49→  while (Date.now() - startTime < MAX_WAIT_MS) {\n    50→    const session = db\n    51→      .select({\n    52→        status: agentSessions.status,\n    53→        completedAt: agentSessions.completedAt,\n    54→      })\n    55→      .from(agentSessions)\n    56→      .where(eq(agentSessions.id, sessionId))\n    57→      .get();\n    58→\n    59→    if (!session) {\n    60→      throw new Error(`Session ${sessionId} not found`);\n    61→    }\n    62→\n    63→    const status = session.status as AgentSessionStatus;\n    64→\n    65→    if (status !== 'active' && status !== 'paused') {\n    66→      return {\n    67→        status,\n    68→        durationMs: Date.now() - startTime,\n    69→      };\n    70→    }\n    71→\n    72→    console.error(`[full-eval] Session ${sessionId} status: ${status}, waiting...`);\n    73→    await new Promise(resolve => setTimeout(resolve, POLL_INTERVAL_MS));\n    74→  }\n    75→\n    76→  throw new Error(`Timeout waiting for session ${sessionId} after ${MAX_WAIT_MS}ms`);\n    77→}\n    78→\n    79→// ─── Main ───────────────────────────────────────────────────────\n    80→\n    81→async function main() {\n    82→  const repoIdArg = process.argv.find(a => a.startsWith('--repo-id='));\n    83→  if (!repoIdArg) {\n    84→    console.error('Usage: pnpm tsx autoresearch/harness/full-eval.ts --repo-id=<id>');\n    85→    process.exit(1);\n    86→  }\n    87→\n    88→  const repositoryId = repoIdArg.split('=')[1];\n    89→  const skipTrigger = process.argv.includes('--skip-trigger');\n    90→\n    91→  let sessionId: string;\n    92→\n    93→  if (skipTrigger) {\n    94→    // Use the latest active/completed session\n    95→    const latest = db\n    96→      .select({ id: agentSessions.id })\n    97→      .from(agentSessions)\n    98→      .where(eq(agentSessions.repositoryId, repositoryId))\n    99→      .orderBy(desc(agentSessions.createdAt))\n   100→      .limit(1)\n   101→      .get();\n   102→\n   103→    if (!latest) {\n   104→      console.error('No agent sessions found');\n   105→      process.exit(1);\n   106→    }\n   107→    sessionId = latest.id;\n   108→    console.error(`[full-eval] Using existing session: ${sessionId}`);\n   109→  } else {\n   110→    console.error(`[full-eval] Triggering Play Agent for repo ${repositoryId}...`);\n   111→    try {\n   112→      sessionId = await triggerPlayAgent(repositoryId);\n   113→      console.error(`[full-eval] Session started: ${sessionId}`);\n   114→    } catch (e) {\n   115→      console.error(`[full-eval] Failed to trigger Play Agent: ${e instanceof Error ? e.message : e}`);\n   116→      console.error('[full-eval] Falling back to latest build metrics...');\n   117→\n   118→      const metrics = await getLatestBuildMetrics(repositoryId);\n   119→      if (!metrics) {\n   120→        console.error('No builds found');\n   121→        process.exit(1);\n   122→      }\n   123→\n   124→      outputMetrics(metrics.buildId, repositoryId, 0);\n   125→      return;\n   126→    }\n   127→  }\n   128→\n   129→  // Wait for completion\n   130→  console.error(`[full-eval] Waiting for session to complete...`);\n   131→  const { status, durationMs } = await waitForCompletion(sessionId);\n   132→  console.error(`[full-eval] Session finished: ${status} (${(durationMs / 1000).toFixed(1)}s)`);\n   133→\n   134→  // Get metrics from the build\n   135→  await outputMetrics(null, repositoryId, durationMs);\n   136→}\n   137→\n   138→async function outputMetrics(\n   139→  buildId: string | null,\n   140→  repositoryId: string,\n   141→  durationMs: number\n   142→) {\n   143→  const metrics = await getLatestBuildMetrics(repositoryId);\n   144→\n   145→  if (!metrics) {\n   146→    console.error('No build metrics available');\n   147→    process.exit(1);\n   148→  }\n   149→\n   150→  console.log('---');\n   151→  console.log(`mode:            full-eval`);\n   152→  console.log(`build_id:        ${metrics.buildId}`);\n   153→  console.log(`pass_rate:       ${metrics.pass_rate.toFixed(6)}`);\n   154→  console.log(`route_accuracy:  ${metrics.route_accuracy.toFixed(6)}`);\n   155→  console.log(`syntax_quality:  ${metrics.syntax_quality.toFixed(6)}`);\n   156→  console.log(`auth_success:    ${metrics.auth_success.toFixed(6)}`);\n   157→  console.log(`route_coverage:  ${metrics.route_coverage.toFixed(6)}`);\n   158→  console.log(`efficiency:      ${metrics.efficiency.toFixed(3)}`);\n   159→  console.log(`passed:          ${metrics.passed}`);\n   160→  console.log(`failed:          ${metrics.failed}`);\n   161→  console.log(`total:           ${metrics.total}`);\n   162→  console.log(`duration_ms:     ${durationMs}`);\n   163→  console.log('---');\n   164→  console.log('failure_breakdown:');\n   165→  for (const [cat, count] of Object.entries(metrics.category_counts)) {\n   166→    if (count > 0) console.log(`  ${cat}: ${count}`);\n   167→  }\n   168→}\n   169→\n   170→main().catch(e => {\n   171→  console.error('Fatal error:', e);\n   172→  process.exit(2);\n   173→});\n   174→"}]},"parent_tool_use_id":null,"session_id":"ec911d5a-d516-40b8-8771-7468f6b1ba97","uuid":"330b6fe6-1cf9-4eb1-acef-2cb73cd053bf","tool_use_result":{"type":"text","file":{"filePath":"/home/ewyct/dev/lastest2/autoresearch/harness/full-eval.ts","content":"/**\n * autoresearch/harness/full-eval.ts — Full Pipeline Eval (IMMUTABLE)\n *\n * Triggers an actual Play Agent run and polls until completion.\n * Outputs metrics in the same parseable format.\n *\n * Usage:\n *   pnpm tsx autoresearch/harness/full-eval.ts --repo-id=<id>\n */\n\n// Allow nested Claude CLI sessions\ndelete process.env.CLAUDECODE;\n\nimport { db } from '@/lib/db';\nimport { agentSessions, builds, testRuns } from '@/lib/db/schema';\nimport { eq, desc, and } from 'drizzle-orm';\nimport { getLatestBuildMetrics } from './metrics';\n\n// ─── Types ──────────────────────────────────────────────────────\n\ntype AgentSessionStatus = 'active' | 'paused' | 'completed' | 'failed' | 'cancelled';\n\n// ─── Config ─────────────────────────────────────────────────────\n\nconst POLL_INTERVAL_MS = 15_000; // 15 seconds\nconst MAX_WAIT_MS = 20 * 60 * 1000; // 20 minutes\n\n// ─── Play Agent Trigger ─────────────────────────────────────────\n\nasync function triggerPlayAgent(repositoryId: string): Promise<string> {\n  // Import startPlayAgent dynamically to avoid server action context issues\n  // Instead, we directly create the agent session and kick off execution\n  // by calling the HTTP endpoint or the function directly\n\n  // Use the server action via dynamic import\n  const { startPlayAgent } = await import('@/server/actions/play-agent');\n  const result = await startPlayAgent(repositoryId);\n  return result.sessionId;\n}\n\n// ─── Polling ────────────────────────────────────────────────────\n\nasync function waitForCompletion(sessionId: string): Promise<{\n  status: AgentSessionStatus;\n  durationMs: number;\n}> {\n  const startTime = Date.now();\n\n  while (Date.now() - startTime < MAX_WAIT_MS) {\n    const session = db\n      .select({\n        status: agentSessions.status,\n        completedAt: agentSessions.completedAt,\n      })\n      .from(agentSessions)\n      .where(eq(agentSessions.id, sessionId))\n      .get();\n\n    if (!session) {\n      throw new Error(`Session ${sessionId} not found`);\n    }\n\n    const status = session.status as AgentSessionStatus;\n\n    if (status !== 'active' && status !== 'paused') {\n      return {\n        status,\n        durationMs: Date.now() - startTime,\n      };\n    }\n\n    console.error(`[full-eval] Session ${sessionId} status: ${status}, waiting...`);\n    await new Promise(resolve => setTimeout(resolve, POLL_INTERVAL_MS));\n  }\n\n  throw new Error(`Timeout waiting for session ${sessionId} after ${MAX_WAIT_MS}ms`);\n}\n\n// ─── Main ───────────────────────────────────────────────────────\n\nasync function main() {\n  const repoIdArg = process.argv.find(a => a.startsWith('--repo-id='));\n  if (!repoIdArg) {\n    console.error('Usage: pnpm tsx autoresearch/harness/full-eval.ts --repo-id=<id>');\n    process.exit(1);\n  }\n\n  const repositoryId = repoIdArg.split('=')[1];\n  const skipTrigger = process.argv.includes('--skip-trigger');\n\n  let sessionId: string;\n\n  if (skipTrigger) {\n    // Use the latest active/completed session\n    const latest = db\n      .select({ id: agentSessions.id })\n      .from(agentSessions)\n      .where(eq(agentSessions.repositoryId, repositoryId))\n      .orderBy(desc(agentSessions.createdAt))\n      .limit(1)\n      .get();\n\n    if (!latest) {\n      console.error('No agent sessions found');\n      process.exit(1);\n    }\n    sessionId = latest.id;\n    console.error(`[full-eval] Using existing session: ${sessionId}`);\n  } else {\n    console.error(`[full-eval] Triggering Play Agent for repo ${repositoryId}...`);\n    try {\n      sessionId = await triggerPlayAgent(repositoryId);\n      console.error(`[full-eval] Session started: ${sessionId}`);\n    } catch (e) {\n      console.error(`[full-eval] Failed to trigger Play Agent: ${e instanceof Error ? e.message : e}`);\n      console.error('[full-eval] Falling back to latest build metrics...');\n\n      const metrics = await getLatestBuildMetrics(repositoryId);\n      if (!metrics) {\n        console.error('No builds found');\n        process.exit(1);\n      }\n\n      outputMetrics(metrics.buildId, repositoryId, 0);\n      return;\n    }\n  }\n\n  // Wait for completion\n  console.error(`[full-eval] Waiting for session to complete...`);\n  const { status, durationMs } = await waitForCompletion(sessionId);\n  console.error(`[full-eval] Session finished: ${status} (${(durationMs / 1000).toFixed(1)}s)`);\n\n  // Get metrics from the build\n  await outputMetrics(null, repositoryId, durationMs);\n}\n\nasync function outputMetrics(\n  buildId: string | null,\n  repositoryId: string,\n  durationMs: number\n) {\n  const metrics = await getLatestBuildMetrics(repositoryId);\n\n  if (!metrics) {\n    console.error('No build metrics available');\n    process.exit(1);\n  }\n\n  console.log('---');\n  console.log(`mode:            full-eval`);\n  console.log(`build_id:        ${metrics.buildId}`);\n  console.log(`pass_rate:       ${metrics.pass_rate.toFixed(6)}`);\n  console.log(`route_accuracy:  ${metrics.route_accuracy.toFixed(6)}`);\n  console.log(`syntax_quality:  ${metrics.syntax_quality.toFixed(6)}`);\n  console.log(`auth_success:    ${metrics.auth_success.toFixed(6)}`);\n  console.log(`route_coverage:  ${metrics.route_coverage.toFixed(6)}`);\n  console.log(`efficiency:      ${metrics.efficiency.toFixed(3)}`);\n  console.log(`passed:          ${metrics.passed}`);\n  console.log(`failed:          ${metrics.failed}`);\n  console.log(`total:           ${metrics.total}`);\n  console.log(`duration_ms:     ${durationMs}`);\n  console.log('---');\n  console.log('failure_breakdown:');\n  for (const [cat, count] of Object.entries(metrics.category_counts)) {\n    if (count > 0) console.log(`  ${cat}: ${count}`);\n  }\n}\n\nmain().catch(e => {\n  console.error('Fatal error:', e);\n  process.exit(2);\n});\n","numLines":174,"startLine":1,"totalLines":174}}}
