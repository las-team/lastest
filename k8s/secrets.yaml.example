# Template only — do NOT commit real secrets.
# The bootstrap script `scripts/k3d-up.sh` generates a concrete,
# gitignored `.k8s-secrets.yaml` from random values at first run.
#
# If you need to rotate, delete `.k8s-secrets.yaml` and re-run k3d-up.sh.
---
apiVersion: v1
kind: Secret
metadata:
  name: postgres-creds
  namespace: lastest
type: Opaque
stringData:
  POSTGRES_USER: lastest
  POSTGRES_PASSWORD: <REPLACE_ME>
  POSTGRES_DB: lastest
---
apiVersion: v1
kind: Secret
metadata:
  name: lastest-app-secrets
  namespace: lastest
type: Opaque
stringData:
  # openssl rand -hex 32
  BETTER_AUTH_SECRET: <REPLACE_ME>
  # openssl rand -hex 32 — shared with every EB pod via provisioner
  SYSTEM_EB_TOKEN: <REPLACE_ME>
  # Must point at the in-cluster postgres Service
  DATABASE_URL: postgresql://lastest:<REPLACE_ME>@postgres.lastest.svc.cluster.local:5432/lastest
