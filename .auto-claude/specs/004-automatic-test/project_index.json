{
  "project_type": "single",
  "services": {
    "frontend": {
      "path": ".",
      "tech_stack": ["typescript", "next.js", "playwright", "drizzle"],
      "port": 3000,
      "dev_command": "pnpm dev",
      "test_command": "pnpm test",
      "lint_command": "pnpm lint"
    }
  },
  "infrastructure": {
    "docker": false,
    "database": "sqlite",
    "ci": "GitHub Actions",
    "ci_workflows": ["regression.yml"]
  },
  "conventions": {
    "linter": "eslint",
    "formatter": null,
    "testing": "vitest",
    "typescript": true
  },
  "key_directories": {
    "playwright": "src/lib/playwright/",
    "scanner": "src/lib/scanner/",
    "db": "src/lib/db/",
    "server_actions": "src/server/actions/",
    "app_routes": "src/app/"
  }
}
