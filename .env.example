# Database
DATABASE_URL=postgresql://lastest:lastest@localhost:5432/lastest

# Embedded Browser provisioning — runs in the EB pool service; start it with
# `pnpm pool` in a second terminal. The pool service also needs ENCRYPTION_KEY
# (below) — it signs the per-session EB_BOOTSTRAP_TOKEN injected into every
# dynamically provisioned EB.
#
# In a dev checkout the default is EB_PROVISIONER=process: EBs are spawned as
# local child processes — no cluster or extra env needed (Playwright Chromium
# must be installed on the host). Tunables:
# EB_PROCESS_POOL_MAX=4
# EB_PROCESS_PORT_BASE=9300
#
# k3d/k8s Job mode (`pnpm stack`) instead needs:
# EB_PROVISIONER=kubernetes
# EB_NAMESPACE=lastest
# EB_IMAGE=lastest-embedded-browser:latest
# LASTEST_URL=http://host.k3d.internal:3000
#
# EB_PROVISIONER=disabled turns dynamic provisioning off entirely.
# SYSTEM_EB_TOKEN is only for STATIC EB fleets (docker-compose replicas) —
# dynamic EBs authenticate with per-session bootstrap tokens instead.
# SYSTEM_EB_TOKEN=

# EB pool service endpoint (app → pool service; defaults shown). Set the token
# only when the service binds beyond loopback (e.g. its own k8s Deployment).
# EB_POOL_SERVICE_URL=http://127.0.0.1:9500
# EB_POOL_SERVICE_TOKEN=

GITHUB_CLIENT_ID=id
GITHUB_CLIENT_SECRET=secret

# Discord OAuth (Sign in with Discord). Register an app at
# https://discord.com/developers/applications and set the OAuth2 redirect URI
# to <BETTER_AUTH_BASE_URL>/api/auth/callback/discord.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# GitLab (gitlab.com SaaS fallback). Self-hosted instances are configured per-team
# via the Self-Hosted dialog (Personal Access Token or per-account OAuth client).
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://localhost:3000/api/connect/gitlab/callback
# Default OAuth instance — only used when no per-team instanceUrl is set.
GITLAB_INSTANCE_URL=https://gitlab.com
# Fallback webhook secret — overridden by per-config webhookSecret (gitlab_pipeline_configs)
# once a project hook is deployed via the GitLab Pipelines settings card.
GITLAB_WEBHOOK_SECRET=

# Bug Reporting (optional — silently skipped if not set)
BUG_REPORT_GITHUB_TOKEN=ghp_...
BUG_REPORT_GITHUB_REPO=owner/repo
BUG_REPORT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Twenty CRM (optional — silently skipped if not set)
TWENTY_API_URL=http://localhost:3000
TWENTY_API_KEY=your-twenty-api-key
TWENTY_COMPANY_ID=your-company-uuid

# Umami analytics (optional — both must be set for client analytics to fire).
# UMAMI_INTERNAL_URL is server-only; the app proxies /_umami/* to it so the
# browser never talks to Umami directly (no public hostname or mixed-content).
# Leave both blank to disable. App is robust to either being missing.
UMAMI_INTERNAL_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Olares-only build override. NEXT_PUBLIC_* vars are inlined at `pnpm build`,
# so a separate ID lets the Olares image track app.lastest.cloud against its
# own Umami site while local dev keeps using NEXT_PUBLIC_UMAMI_WEBSITE_ID.
# Consumed by build_olares() in scripts/deploy.sh; ignored elsewhere.
OLARES_UMAMI_WEBSITE_ID=

# ─────────────────────────────────────────────────────────────────────
# Stripe billing (optional — checkout buttons are hidden when unset).
# ─────────────────────────────────────────────────────────────────────
#
# v1 is monthly + yearly subscriptions, with early-adopter discounts on
# both. Powered by @better-auth/stripe — the plugin owns subscription
# lifecycle, customer creation, and the webhook handler at
# /api/auth/stripe/webhook.
#
# Setup against your Stripe TEST account:
#
#  1. https://dashboard.stripe.com — toggle to Test Mode (top-right).
#
#  2. Developers → API keys → "Create restricted key" (rk_test_...) and
#     put it in STRIPE_SECRET_KEY. Prefer a restricted key (RAK) over the
#     account secret key (sk_test_...) — least privilege limits blast
#     radius if the key leaks. Grant WRITE on:
#        Customers, Checkout Sessions, Subscriptions,
#        Billing Portal (sessions), Customer portal
#     and READ on:
#        Products, Prices
#     (A plain sk_test_ secret key also works, just not recommended.
#     For production, create a separate live-mode RAK and consider
#     adding an IP allowlist to it in the Dashboard.)
#     Note: the provisioning script in step 3 needs WRITE on Products +
#     Prices — run it with a separate provisioning key (or temporarily
#     grant write, then dial back to read), so the long-lived app key
#     keeps the minimal permissions above.
#
#  3. Provision the product catalog:
#        STRIPE_SECRET_KEY=rk_test_... node scripts/stripe-provision-test.mjs
#     This creates one Product per tier (Starter / Growth / Pro) with
#     the metadata the app reads at runtime (tier, quotas, tagline,
#     marketing_features = feature bullets) and four recurring Prices
#     each, identified by lookup keys ({tier}_monthly, {tier}_monthly_ea,
#     {tier}_yearly, {tier}_yearly_ea). There are NO price-ID env vars —
#     the app discovers the catalog via the Stripe API (10-min cache,
#     busted by product./price. webhooks), so dashboard edits to prices,
#     quotas, or bullets go live without a deploy. EA prices are
#     optional — checkout falls through to the full price.
#
#  4. Developers → Webhooks → "Add endpoint" pointed at
#     <APP_URL>/api/auth/stripe/webhook. Subscribe to:
#        checkout.session.completed
#        customer.subscription.created
#        customer.subscription.updated
#        customer.subscription.deleted
#        product.updated           (catalog cache invalidation)
#        product.created
#        price.updated             (catalog cache invalidation)
#        price.created
#        invoice.paid              (optional, for status sync)
#        invoice.payment_failed    (optional)
#     Copy the "Signing secret" (whsec_xxx) into STRIPE_WEBHOOK_SECRET.
#
#  5. Local dev: `stripe listen --forward-to localhost:3000/api/auth/stripe/webhook`
#     forwards live events to your dev server; use the whsec_ it prints.
#
#  6. Test card: 4242 4242 4242 4242, any future expiry, any CVC, any ZIP.
#     `managed_payments: { enabled: true }` is on by default so the
#     Checkout page renders Stripe-orchestrated payment methods + 3DS.
#
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Flip to "false" to close the early-adopter window. UI then displays
# (and Checkout charges) the full prices instead of the *_ea ones.
EARLY_ADOPTER_PRICING=true

# Encryption key for OAuth tokens and AI API keys stored in the database.
# Generate with: openssl rand -hex 32
# Must be set before first run. Required — the app throws on startup if missing.
ENCRYPTION_KEY=

# Key rotation: when rotating to a new key, set OLD_ENCRYPTION_KEY to the
# previous value and run:
#   OLD_ENCRYPTION_KEY=<old> pnpm tsx --env-file=.env scripts/rotate-encryption-key.ts --dry-run
#   OLD_ENCRYPTION_KEY=<old> pnpm tsx --env-file=.env scripts/rotate-encryption-key.ts
# Then remove OLD_ENCRYPTION_KEY once the script completes.
# OLD_ENCRYPTION_KEY=

# Grant lifetime in seconds (default 1800, matching the EB Job's
# activeDeadlineSeconds). Must outlive a viewer's reconnect attempts, since a
# grant is minted once when the stream URL is handed out.
# EB_STREAM_GRANT_TTL_SECONDS=1800
